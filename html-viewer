<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>HTML Viewer</title>
  <style>
    body { font-family: sans-serif; padding: 16px; }
    textarea { width: 100%; height: 150px; font-family: monospace; }
    iframe { width: 100%; height: 200px; border: 1px solid #ccc; margin-top: 10px; }
    button { margin-top: 10px; padding: 8px 16px; cursor: pointer; }
  </style>
</head>
<body>
  <h2>Colle ton code HTML ici 👇</h2>
  <textarea id="htmlInput" placeholder="Colle ton code HTML, CSS ou JS ici..."></textarea>
  <button id="previewBtn">Afficher l’aperçu</button>
  <iframe id="previewFrame"></iframe>

  <script>
    document.getElementById('previewBtn').onclick = () => {
      const code = document.getElementById('htmlInput').value;
      const iframe = document.getElementById('previewFrame');
      iframe.srcdoc = code; // affiche directement ton code HTML dans l’iframe
    };
  </script>
</body>
</html>
